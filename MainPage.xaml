<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Ficsit.Schematics"
             xmlns:vm="clr-namespace:Ficsit.Schematics.ViewModels"
             x:Class="Ficsit.Schematics.MainPage"
             x:DataType="local:MainPage"
             BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#121212}">

    <ContentPage.Resources>
        <!-- ============ palette ============ -->
        <Color x:Key="Accent">#F89B4B</Color>
        <Color x:Key="AccentDeep">#E8772E</Color>

        <!-- ============ surfaces ============ -->
        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F7FFFFFF, Dark=#F51E1E1E}" />
            <Setter Property="Stroke" Value="{AppThemeBinding Light=#E0E0E0, Dark=#383838}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="StrokeShape" Value="RoundRectangle 12" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Shadow">
                <Setter.Value>
                    <Shadow Brush="Black" Opacity="0.35" Radius="20" Offset="0,6" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Pill" TargetType="Border" BasedOn="{StaticResource Panel}">
            <Setter Property="StrokeShape" Value="RoundRectangle 10" />
            <Setter Property="Padding" Value="4" />
        </Style>
        <Style x:Key="Divider" TargetType="BoxView">
            <Setter Property="WidthRequest" Value="1" />
            <Setter Property="Margin" Value="3,6" />
            <Setter Property="Color" Value="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3A}" />
        </Style>
        <Style x:Key="HDivider" TargetType="BoxView">
            <Setter Property="HeightRequest" Value="1" />
            <Setter Property="Margin" Value="0,6" />
            <Setter Property="Color" Value="{AppThemeBinding Light=#E8E8E8, Dark=#333333}" />
        </Style>

        <!-- ============ buttons ============ -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#333333, Dark=#E6E6E6}" />
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="WidthRequest" Value="36" />
            <Setter Property="HeightRequest" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="Transparent" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="PointerOver">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#14000000, Dark=#1FFFFFFF}" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Pressed">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#22000000, Dark=#33FFFFFF}" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Disabled">
                            <VisualState.Setters>
                                <Setter Property="TextColor" Value="{AppThemeBinding Light=#B5B5B5, Dark=#5A5A5A}" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
        <Style x:Key="TextButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Setter Property="FontFamily" Value="OpenSansRegular" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="WidthRequest" Value="-1" />
            <Setter Property="Padding" Value="12,0" />
        </Style>
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource TextButton}">
            <Setter Property="BackgroundColor" Value="{StaticResource Accent}" />
            <Setter Property="TextColor" Value="#1A1208" />
            <Setter Property="FontFamily" Value="OpenSansSemibold" />
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="{StaticResource Accent}" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="PointerOver">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="{StaticResource AccentDeep}" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#C62838, Dark=#FF6B81}" />
        </Style>
        <Style x:Key="Chip" TargetType="Button">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="HeightRequest" Value="26" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="CornerRadius" Value="13" />
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#EBEBEB, Dark=#2E2E2E}" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#444444, Dark=#CCCCCC}" />
        </Style>

        <!-- ============ text + fields ============ -->
        <Style x:Key="RowLabel" TargetType="Label">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#333333, Dark=#DDDDDD}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="VerticalOptions" Value="Center" />
        </Style>
        <Style x:Key="MutedLabel" TargetType="Label" BasedOn="{StaticResource RowLabel}">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#8A8A8A, Dark=#8C8C8C}" />
            <Setter Property="FontSize" Value="11" />
        </Style>
        <Style x:Key="SectionHeader" TargetType="Label">
            <Setter Property="TextColor" Value="{StaticResource Accent}" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="FontFamily" Value="OpenSansSemibold" />
            <Setter Property="CharacterSpacing" Value="1.2" />
            <Setter Property="Margin" Value="2,10,0,4" />
        </Style>
        <Style x:Key="PanelTitle" TargetType="Label">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#1A1A1A, Dark=#F2F2F2}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontFamily" Value="OpenSansSemibold" />
            <Setter Property="VerticalOptions" Value="Center" />
        </Style>
        <Style x:Key="FieldEntry" TargetType="Entry">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#1A1A1A, Dark=#F2F2F2}" />
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F0F0F0, Dark=#2C2C2C}" />
            <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light=#9A9A9A, Dark=#777777}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="HeightRequest" Value="32" />
        </Style>
        <Style TargetType="Picker">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#1A1A1A, Dark=#F2F2F2}" />
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="FontSize" Value="12.5" />
        </Style>
        <Style TargetType="Switch">
            <Setter Property="OnColor" Value="{StaticResource Accent}" />
        </Style>

        <Style x:Key="ListRow" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F4F4F4, Dark=#272727}" />
            <Setter Property="Stroke" Value="Transparent" />
            <Setter Property="StrokeShape" Value="RoundRectangle 8" />
            <Setter Property="Padding" Value="8,5" />
        </Style>
    </ContentPage.Resources>

    <Grid>
        <GraphicsView x:Name="Canvas" />

        <!-- ====================== toolbar (top left) ====================== -->
        <Border Style="{StaticResource Pill}" HorizontalOptions="Start" VerticalOptions="Start" Margin="12">
            <HorizontalStackLayout Spacing="1">
                <Button x:Name="UndoButton" Style="{StaticResource IconButton}" Text="&#xE7A7;" Clicked="OnUndoClicked" />
                <Button x:Name="RedoButton" Style="{StaticResource IconButton}" Text="&#xE7A6;" Clicked="OnRedoClicked" />
                <BoxView Style="{StaticResource Divider}" />
                <Button x:Name="ZoomOutButton" Style="{StaticResource IconButton}" Text="&#xE71F;" Clicked="OnZoomOutClicked" />
                <Button x:Name="ZoomResetButton" Style="{StaticResource TextButton}" Text="100%" FontSize="11.5" WidthRequest="52" Padding="0" Clicked="OnZoomResetClicked" />
                <Button x:Name="ZoomInButton" Style="{StaticResource IconButton}" Text="&#xE8A3;" Clicked="OnZoomInClicked" />
                <Button x:Name="ZoomFitButton" Style="{StaticResource IconButton}" Text="&#xE9A6;" Clicked="OnZoomFitClicked" />
                <BoxView Style="{StaticResource Divider}" />
                <Button x:Name="SummaryButton" Style="{StaticResource IconButton}" Text="&#xE9D2;" Clicked="OnSummaryToggleClicked" />
                <Button x:Name="MapButton" Style="{StaticResource IconButton}" Text="&#xE774;" Clicked="OnMapToggleClicked" />
                <Button x:Name="AutoPlanButton" Style="{StaticResource IconButton}" Text="&#xE945;" Clicked="OnAutoPlanClicked" />
            </HorizontalStackLayout>
        </Border>

        <!-- ====================== scope breadcrumb (top center) ====================== -->
        <Border x:Name="ScopePill" Style="{StaticResource Pill}" IsVisible="False"
                HorizontalOptions="Center" VerticalOptions="Start" Margin="0,12,0,0" Padding="4,4,14,4">
            <HorizontalStackLayout Spacing="6">
                <Button x:Name="ScopeBackButton" Style="{StaticResource IconButton}" Text="&#xE72B;" Clicked="OnScopeBackClicked" />
                <Label x:Name="ScopeLabel" Style="{StaticResource RowLabel}" FontFamily="OpenSansSemibold" />
            </HorizontalStackLayout>
        </Border>

        <!-- ====================== file / app actions (top right) ====================== -->
        <Border Style="{StaticResource Pill}" HorizontalOptions="End" VerticalOptions="Start" Margin="12">
            <HorizontalStackLayout Spacing="1">
                <Button x:Name="ImportButton" Style="{StaticResource IconButton}" Text="&#xE8E5;" Clicked="OnImportClicked" />
                <Button x:Name="ExportButton" Style="{StaticResource IconButton}" Text="&#xEDE1;" Clicked="OnExportClicked" />
                <Button x:Name="SavesButton" Style="{StaticResource IconButton}" Text="&#xE8F1;" Clicked="OnSavesClicked" />
                <BoxView Style="{StaticResource Divider}" />
                <Button x:Name="SettingsButton" Style="{StaticResource IconButton}" Text="&#xE713;" Clicked="OnSettingsClicked" />
            </HorizontalStackLayout>
        </Border>

        <!-- ====================== status (bottom right) ====================== -->
        <Border Style="{StaticResource Pill}" HorizontalOptions="End" VerticalOptions="End" Margin="12" Padding="12,6">
            <Label x:Name="StatusLabel" Style="{StaticResource MutedLabel}" />
        </Border>

        <!-- ====================== summary panel (left) ====================== -->
        <Border x:Name="SummaryPanel" Style="{StaticResource Panel}" IsVisible="False"
                WidthRequest="280" HorizontalOptions="Start" VerticalOptions="Fill" Margin="12,60,0,12">
            <Grid RowDefinitions="Auto,Auto,*">
                <Label x:Name="SummaryTitle" Style="{StaticResource PanelTitle}" />
                <Picker x:Name="SummaryScope" Grid.Row="1" Margin="0,4,0,0"
                        ItemsSource="{Binding Summary.Scopes}"
                        SelectedItem="{Binding Summary.Scope, Mode=TwoWay}" />
                <ScrollView Grid.Row="2">
                    <VerticalStackLayout Spacing="2">
                        <Label x:Name="SummaryPowerHeader" Style="{StaticResource SectionHeader}" />
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Summary.PowerRows}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:SummaryRow">
                                    <Grid ColumnDefinitions="*,Auto" Padding="4,2">
                                        <Label Text="{Binding Label}" Style="{StaticResource RowLabel}" FontSize="11.5" />
                                        <Label Grid.Column="1" Text="{Binding Value}" Style="{StaticResource RowLabel}" FontSize="11.5" FontFamily="OpenSansSemibold" />
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <Label x:Name="SummaryOverclockHeader" Style="{StaticResource SectionHeader}" />
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Summary.OverclockRows}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:SummaryRow">
                                    <Grid ColumnDefinitions="*,Auto" Padding="4,2">
                                        <Label Text="{Binding Label}" Style="{StaticResource RowLabel}" FontSize="11.5" />
                                        <Label Grid.Column="1" Text="{Binding Value}" Style="{StaticResource RowLabel}" FontSize="11.5" FontFamily="OpenSansSemibold" />
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <Label x:Name="SummaryOutputHeader" Style="{StaticResource SectionHeader}" />
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Summary.OutputRows}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:SummaryRow">
                                    <Grid ColumnDefinitions="20,*,Auto" Padding="4,2" ColumnSpacing="6">
                                        <Image Source="{Binding Icon}" WidthRequest="16" HeightRequest="16" VerticalOptions="Center" />
                                        <Label Grid.Column="1" Text="{Binding Label}" Style="{StaticResource RowLabel}" FontSize="11.5" LineBreakMode="TailTruncation" />
                                        <Label Grid.Column="2" Text="{Binding Value}" Style="{StaticResource RowLabel}" FontSize="11.5" FontFamily="OpenSansSemibold" />
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <Label x:Name="SummaryInputHeader" Style="{StaticResource SectionHeader}" />
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Summary.InputRows}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:SummaryRow">
                                    <Grid ColumnDefinitions="20,*,Auto" Padding="4,2" ColumnSpacing="6">
                                        <Image Source="{Binding Icon}" WidthRequest="16" HeightRequest="16" VerticalOptions="Center" />
                                        <Label Grid.Column="1" Text="{Binding Label}" Style="{StaticResource RowLabel}" FontSize="11.5" LineBreakMode="TailTruncation" />
                                        <Label Grid.Column="2" Text="{Binding Value}" Style="{StaticResource RowLabel}" FontSize="11.5" FontFamily="OpenSansSemibold" />
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Border>

        <!-- ====================== recipe chooser ====================== -->
        <Border x:Name="ChooserPanel" Style="{StaticResource Panel}" IsVisible="False"
                HorizontalOptions="Start" VerticalOptions="Start" WidthRequest="470" HeightRequest="440">
            <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8">
                <Entry x:Name="ChooserSearch" Style="{StaticResource FieldEntry}"
                       Text="{Binding Chooser.SearchText, Mode=TwoWay}"
                       Completed="OnChooserSearchCompleted" />
                <HorizontalStackLayout x:Name="ChooserFilterRow" Grid.Row="1" Spacing="6" IsVisible="False">
                    <Border BackgroundColor="#2EF89B4B" Stroke="{StaticResource Accent}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 13" Padding="10,2">
                        <HorizontalStackLayout Spacing="6">
                            <Image x:Name="ChooserFilterIcon" WidthRequest="16" HeightRequest="16" VerticalOptions="Center" />
                            <Label x:Name="ChooserFilterLabel" Style="{StaticResource RowLabel}" FontSize="11.5"
                                   FontFamily="OpenSansSemibold" VerticalOptions="Center" />
                            <Button Style="{StaticResource IconButton}" Text="&#xE8BB;" FontSize="9"
                                    WidthRequest="22" HeightRequest="22" Clicked="OnChooserFilterCleared" />
                        </HorizontalStackLayout>
                    </Border>
                </HorizontalStackLayout>
                <HorizontalStackLayout Grid.Row="2" Spacing="6">
                    <Label x:Name="ChooserMatchLabel" Style="{StaticResource MutedLabel}" VerticalOptions="Center" />
                    <Button x:Name="MatchNameChip" Style="{StaticResource Chip}" Clicked="OnMatchNameChipClicked" />
                    <Button x:Name="MatchInputsChip" Style="{StaticResource Chip}" Clicked="OnMatchInputsChipClicked" />
                    <Button x:Name="MatchOutputsChip" Style="{StaticResource Chip}" Clicked="OnMatchOutputsChipClicked" />
                </HorizontalStackLayout>
                <Grid Grid.Row="3" ColumnDefinitions="160,*" ColumnSpacing="10">
                    <ScrollView>
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Chooser.Specialty}" Spacing="4">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:RecipeListItem">
                                    <Border Style="{StaticResource ListRow}">
                                        <Grid ColumnDefinitions="24,*" ColumnSpacing="6">
                                            <Image Source="{Binding Icon}" WidthRequest="20" HeightRequest="20" VerticalOptions="Center" />
                                            <Label Grid.Column="1" Text="{Binding DisplayName}" Style="{StaticResource RowLabel}" FontSize="11.5" LineBreakMode="TailTruncation" />
                                        </Grid>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnSpecialtyChosen" CommandParameter="{Binding Name}" />
                                        </Border.GestureRecognizers>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </ScrollView>
                    <CollectionView x:Name="ChooserRecipes" Grid.Column="1"
                                    ItemsSource="{Binding Chooser.Recipes}"
                                    SelectionMode="None"
                                    ItemSizingStrategy="MeasureFirstItem">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:RecipeListItem">
                                <Border Style="{StaticResource ListRow}" Margin="0,2">
                                    <Grid ColumnDefinitions="24,*" ColumnSpacing="6">
                                        <Image Source="{Binding Icon}" WidthRequest="20" HeightRequest="20" VerticalOptions="Center" />
                                        <Label Grid.Column="1" Text="{Binding DisplayName}" Style="{StaticResource RowLabel}" FontSize="11.5" LineBreakMode="TailTruncation" />
                                    </Grid>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnRecipeChosen" CommandParameter="{Binding Name}" />
                                    </Border.GestureRecognizers>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Grid>
        </Border>

        <!-- ====================== machine editor popover ====================== -->
        <Border x:Name="MachinePopup" Style="{StaticResource Panel}" IsVisible="False"
                HorizontalOptions="Start" VerticalOptions="Start" WidthRequest="290">
            <VerticalStackLayout Spacing="7">
                <Grid ColumnDefinitions="28,*,Auto" ColumnSpacing="8">
                    <Image x:Name="PopupIcon" WidthRequest="24" HeightRequest="24" VerticalOptions="Center" />
                    <Label x:Name="PopupName" Grid.Column="1" Style="{StaticResource PanelTitle}" FontSize="13.5" LineBreakMode="TailTruncation" />
                    <Button Grid.Column="2" Style="{StaticResource IconButton}" Text="&#xE8BB;" FontSize="11"
                            WidthRequest="30" HeightRequest="28" Clicked="OnPopupCloseClicked" />
                </Grid>
                <BoxView Style="{StaticResource HDivider}" Margin="0,0" />

                <Entry x:Name="PopupTitleEntry" Style="{StaticResource FieldEntry}" Completed="OnPopupTitleCompleted" />

                <!-- recipe / fuel switcher: every recipe this machine can run -->
                <Grid x:Name="PopupRecipeRow" ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <Label x:Name="PopupRecipeLabel" Style="{StaticResource RowLabel}" />
                    <Picker x:Name="PopupRecipePicker" Grid.Column="1" WidthRequest="150" SelectedIndexChanged="OnPopupRecipeChanged" />
                </Grid>

                <Grid x:Name="PopupClockRow" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="4">
                    <Label x:Name="PopupClockLabel" Style="{StaticResource RowLabel}" />
                    <Entry x:Name="PopupClockEntry" Grid.Column="1" Style="{StaticResource FieldEntry}" Margin="8,0,0,0"
                           HorizontalTextAlignment="End" Completed="OnPopupClockCompleted" />
                    <Button Grid.Column="2" Style="{StaticResource IconButton}" Text="&#xE738;" FontSize="11" WidthRequest="30" Clicked="OnClockStepDown" />
                    <Button Grid.Column="3" Style="{StaticResource IconButton}" Text="&#xE710;" FontSize="11" WidthRequest="30" Clicked="OnClockStepUp" />
                </Grid>

                <!-- Auto-Round replaces the free clock entry: read-only "N × clock%"
                     with a machine-count stepper (− = more machines, + = fewer). -->
                <Grid x:Name="PopupAutoClockRow" IsVisible="False" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="4">
                    <Label x:Name="PopupAutoClockLabel" Style="{StaticResource RowLabel}" />
                    <Label x:Name="PopupAutoClockValue" Grid.Column="1" Style="{StaticResource RowLabel}"
                           FontFamily="OpenSansSemibold" HorizontalTextAlignment="End" Margin="0,0,8,0" />
                    <Button x:Name="PopupAutoClockDownButton" Grid.Column="2" Style="{StaticResource IconButton}" Text="&#xE738;" FontSize="11" WidthRequest="30" Clicked="OnAutoRoundStepDown" />
                    <Button x:Name="PopupAutoClockUpButton" Grid.Column="3" Style="{StaticResource IconButton}" Text="&#xE710;" FontSize="11" WidthRequest="30" Clicked="OnAutoRoundStepUp" />
                </Grid>

                <Grid x:Name="PopupSloopRow" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="4">
                    <Label x:Name="PopupSloopLabel" Style="{StaticResource RowLabel}" />
                    <Label x:Name="PopupSloopValue" Grid.Column="1" Style="{StaticResource RowLabel}"
                           FontFamily="OpenSansSemibold" HorizontalTextAlignment="End" Margin="0,0,8,0" />
                    <Button Grid.Column="2" Style="{StaticResource IconButton}" Text="&#xE738;" FontSize="11" WidthRequest="30" Clicked="OnSloopDown" />
                    <Button Grid.Column="3" Style="{StaticResource IconButton}" Text="&#xE710;" FontSize="11" WidthRequest="30" Clicked="OnSloopUp" />
                </Grid>

                <Grid x:Name="PopupAutoRoundRow" ColumnDefinitions="*,Auto">
                    <Label x:Name="PopupAutoRoundLabel" Style="{StaticResource RowLabel}" />
                    <Switch x:Name="PopupAutoRoundSwitch" Grid.Column="1" Toggled="OnAutoRoundToggled" />
                </Grid>

                <Grid x:Name="PopupPpmRow" ColumnDefinitions="*,Auto">
                    <Label x:Name="PopupPpmLabel" Style="{StaticResource RowLabel}" />
                    <Switch x:Name="PopupPpmSwitch" Grid.Column="1" Toggled="OnPpmToggled" />
                </Grid>

                <Grid x:Name="PopupStorageRow" ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <Label x:Name="PopupStorageLabel" Style="{StaticResource RowLabel}" />
                    <Picker x:Name="PopupStoragePicker" Grid.Column="1" WidthRequest="150" SelectedIndexChanged="OnStorageModeChanged" />
                </Grid>

                <Grid x:Name="PopupVariantRow" ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <Label x:Name="PopupVariantLabel" Style="{StaticResource RowLabel}" />
                    <Picker x:Name="PopupVariantPicker" Grid.Column="1" WidthRequest="150" SelectedIndexChanged="OnVariantChanged" />
                </Grid>

                <Grid x:Name="PopupCapacityRow" ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <Label x:Name="PopupCapacityLabel" Style="{StaticResource RowLabel}" />
                    <Picker x:Name="PopupCapacityPicker" Grid.Column="1" WidthRequest="150" SelectedIndexChanged="OnCapacityChanged" />
                </Grid>

                <BoxView Style="{StaticResource HDivider}" Margin="0,0" />
                <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto" ColumnSpacing="2">
                    <Button x:Name="PopupCutButton" Style="{StaticResource IconButton}" Text="&#xE8C6;" Clicked="OnCutClicked" />
                    <Button x:Name="PopupCopyButton" Grid.Column="1" Style="{StaticResource IconButton}" Text="&#xE8C8;" Clicked="OnCopyClicked" />
                    <Button x:Name="PopupPasteButton" Grid.Column="2" Style="{StaticResource IconButton}" Text="&#xE77F;" Clicked="OnPasteClicked" />
                    <Button x:Name="PopupDeleteButton" Grid.Column="4" Style="{StaticResource DangerButton}" Text="&#xE74D;" Clicked="OnPopupDeleteClicked" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- ====================== settings panel ====================== -->
        <Border x:Name="SettingsPanel" Style="{StaticResource Panel}" IsVisible="False"
                HorizontalOptions="End" VerticalOptions="Start" Margin="12,60,12,12" WidthRequest="330">
            <ScrollView MaximumHeightRequest="600">
                <VerticalStackLayout Spacing="7">
                    <Label x:Name="SettingsTitle" Style="{StaticResource PanelTitle}" />

                    <Label x:Name="SettingsGeneralHeader" Style="{StaticResource SectionHeader}" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                        <Label x:Name="LanguageLabel" Style="{StaticResource RowLabel}" />
                        <Picker x:Name="LanguagePicker" Grid.Column="1" WidthRequest="160" SelectedIndexChanged="OnLanguageChanged" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label x:Name="DarkModeLabel" Style="{StaticResource RowLabel}" />
                        <Switch x:Name="DarkModeSwitch" Grid.Column="1" Toggled="OnDarkModeToggled" />
                    </Grid>
                    <Grid ColumnDefinitions="*,90" ColumnSpacing="6">
                        <Label x:Name="DragSensitivityLabel" Style="{StaticResource RowLabel}" />
                        <Entry x:Name="DragSensitivityEntry" Grid.Column="1" Style="{StaticResource FieldEntry}"
                               HorizontalTextAlignment="End" Completed="OnDragSensitivityChanged" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                        <Label x:Name="CalculatorLabel" Style="{StaticResource RowLabel}" />
                        <Picker x:Name="SolverPicker" Grid.Column="1" WidthRequest="130" SelectedIndexChanged="OnSolverChanged" />
                    </Grid>

                    <Label x:Name="SettingsStyleHeader" Style="{StaticResource SectionHeader}" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                        <Label x:Name="PathStyleLabel" Style="{StaticResource RowLabel}" />
                        <Picker x:Name="PathStylePicker" Grid.Column="1" WidthRequest="130" SelectedIndexChanged="OnPathStyleChanged" />
                    </Grid>

                    <Label x:Name="SettingsMapHeader" Style="{StaticResource SectionHeader}" />
                    <Button x:Name="ImportSaveButton" Style="{StaticResource TextButton}" FontSize="12"
                            HorizontalOptions="Start" Clicked="OnImportSaveClicked" />
                    <Label x:Name="MapNodesInfo" Style="{StaticResource MutedLabel}" Margin="2,0,0,0" />

                    <Label x:Name="SettingsMultipliersHeader" Style="{StaticResource SectionHeader}" />
                    <Grid ColumnDefinitions="*,90" ColumnSpacing="6">
                        <Label x:Name="SpaceElevatorMultLabel" Style="{StaticResource RowLabel}" FontSize="11.5" />
                        <Entry x:Name="SpaceElevatorMultEntry" Grid.Column="1" Style="{StaticResource FieldEntry}"
                               HorizontalTextAlignment="End" Completed="OnMultiplierChanged" />
                    </Grid>
                    <Grid ColumnDefinitions="*,90" ColumnSpacing="6">
                        <Label x:Name="InputMultLabel" Style="{StaticResource RowLabel}" FontSize="11.5" />
                        <Entry x:Name="InputMultEntry" Grid.Column="1" Style="{StaticResource FieldEntry}"
                               HorizontalTextAlignment="End" Completed="OnMultiplierChanged" />
                    </Grid>
                    <Grid ColumnDefinitions="*,90" ColumnSpacing="6">
                        <Label x:Name="PowerMultLabel" Style="{StaticResource RowLabel}" FontSize="11.5" />
                        <Entry x:Name="PowerMultEntry" Grid.Column="1" Style="{StaticResource FieldEntry}"
                               HorizontalTextAlignment="End" Completed="OnMultiplierChanged" />
                    </Grid>

                    <Label x:Name="SettingsAutosaveHeader" Style="{StaticResource SectionHeader}" />
                    <Grid ColumnDefinitions="*,Auto">
                        <Label x:Name="AutosaveLabel" Style="{StaticResource RowLabel}" />
                        <Switch x:Name="AutosaveSwitch" Grid.Column="1" Toggled="OnAutosaveToggled" />
                    </Grid>
                    <Grid ColumnDefinitions="*,90" ColumnSpacing="6">
                        <Label x:Name="AutosaveIntervalLabel" Style="{StaticResource RowLabel}" FontSize="11.5" />
                        <Entry x:Name="AutosaveIntervalEntry" Grid.Column="1" Style="{StaticResource FieldEntry}"
                               HorizontalTextAlignment="End" Completed="OnAutosaveIntervalChanged" />
                    </Grid>

                    <BoxView Style="{StaticResource HDivider}" />
                    <HorizontalStackLayout Spacing="4">
                        <Button x:Name="HelpButton" Style="{StaticResource TextButton}" FontSize="12" Clicked="OnHelpClicked" />
                        <Button x:Name="AboutButton" Style="{StaticResource TextButton}" FontSize="12" Clicked="OnAboutClicked" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </ScrollView>
        </Border>

        <!-- ====================== saves panel ====================== -->
        <Border x:Name="SavesPanel" Style="{StaticResource Panel}" IsVisible="False"
                HorizontalOptions="End" VerticalOptions="Start" Margin="12,60,12,12" WidthRequest="350">
            <VerticalStackLayout Spacing="7">
                <Label x:Name="SavesTitle" Style="{StaticResource PanelTitle}" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <Entry x:Name="SaveNameEntry" Style="{StaticResource FieldEntry}" Completed="OnSaveAsClicked" />
                    <Button x:Name="SaveAsButton" Grid.Column="1" Style="{StaticResource AccentButton}" Clicked="OnSaveAsClicked" />
                </Grid>
                <ScrollView MaximumHeightRequest="240">
                    <VerticalStackLayout x:Name="SavesList" Spacing="4" />
                </ScrollView>
                <Label x:Name="BackupsHeader" Style="{StaticResource SectionHeader}" />
                <ScrollView MaximumHeightRequest="200">
                    <VerticalStackLayout x:Name="BackupsList" Spacing="4" />
                </ScrollView>
            </VerticalStackLayout>
        </Border>

        <!-- ====================== auto-plan panel ====================== -->
        <Border x:Name="AutoPlanPanel" Style="{StaticResource Panel}" IsVisible="False"
                HorizontalOptions="End" VerticalOptions="Start" Margin="12,60,12,12" WidthRequest="380">
            <ScrollView MaximumHeightRequest="640">
                <VerticalStackLayout Spacing="7">
                    <Label x:Name="AutoPlanTitle" Style="{StaticResource PanelTitle}" />

                    <Label x:Name="PlanTargetsHeader" Style="{StaticResource SectionHeader}" />
                    <VerticalStackLayout x:Name="PlanTargetsList" Spacing="4" />
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                        <Button x:Name="PlanAddTargetButton" Style="{StaticResource IconButton}" Text="&#xE710;" Clicked="OnPlanAddTarget" />
                        <Picker x:Name="PlanPhasePicker" Grid.Column="1" SelectedIndexChanged="OnPlanPhasePicked" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label x:Name="PlanMaximizeLabel" Style="{StaticResource RowLabel}" FontSize="11.5" />
                        <Switch x:Name="PlanMaximizeSwitch" Grid.Column="1" />
                    </Grid>

                    <Label x:Name="PlanProvidedHeader" Style="{StaticResource SectionHeader}" />
                    <VerticalStackLayout x:Name="PlanProvisionsList" Spacing="4" />
                    <Button x:Name="PlanAddProvisionButton" Style="{StaticResource IconButton}" Text="&#xE710;" HorizontalOptions="Start" Clicked="OnPlanAddProvision" />

                    <Label x:Name="PlanBannedHeader" Style="{StaticResource SectionHeader}" />
                    <FlexLayout x:Name="PlanBannedChips" Wrap="Wrap" Direction="Row" JustifyContent="Start" AlignItems="Center" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                        <Label x:Name="PlanBiasLabel" Style="{StaticResource RowLabel}" />
                        <Picker x:Name="PlanBiasPicker" Grid.Column="1" WidthRequest="150" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                        <Label x:Name="PlanByproductLabel" Style="{StaticResource RowLabel}" />
                        <Picker x:Name="PlanByproductPicker" Grid.Column="1" WidthRequest="150" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label x:Name="PlanAlternatesLabel" Style="{StaticResource RowLabel}" />
                        <Switch x:Name="PlanAlternatesSwitch" Grid.Column="1" IsToggled="True" />
                    </Grid>

                    <Button x:Name="PlanRunButton" Style="{StaticResource AccentButton}" Clicked="OnPlanRunClicked" />
                    <Label x:Name="PlanSummaryLabel" Style="{StaticResource MutedLabel}" LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </ScrollView>
        </Border>

        <!-- part picker for the auto-plan rows -->
        <Border x:Name="PartPickerPanel" Style="{StaticResource Panel}" IsVisible="False"
                HorizontalOptions="End" VerticalOptions="Start" Margin="12,60,404,12"
                WidthRequest="300" HeightRequest="440">
            <Grid RowDefinitions="Auto,*" RowSpacing="8">
                <Entry x:Name="PartPickerSearch" Style="{StaticResource FieldEntry}" TextChanged="OnPartPickerSearch" />
                <CollectionView x:Name="PartPickerList" Grid.Row="1" SelectionMode="None" ItemSizingStrategy="MeasureFirstItem">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:RecipeListItem">
                            <Border Style="{StaticResource ListRow}" Margin="0,2">
                                <Grid ColumnDefinitions="24,*" ColumnSpacing="6">
                                    <Image Source="{Binding Icon}" WidthRequest="20" HeightRequest="20" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding DisplayName}" Style="{StaticResource RowLabel}" FontSize="11.5" LineBreakMode="TailTruncation" />
                                </Grid>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPartPicked" CommandParameter="{Binding Name}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>

        <!-- inline limit editor, floats over the node's limit box -->
        <Entry x:Name="LimitEditor" Style="{StaticResource FieldEntry}" IsVisible="False"
               HorizontalOptions="Start" VerticalOptions="Start" FontSize="11" HeightRequest="26"
               HorizontalTextAlignment="Center"
               Completed="OnLimitEditorCompleted" Unfocused="OnLimitEditorUnfocused" />
    </Grid>
</ContentPage>
