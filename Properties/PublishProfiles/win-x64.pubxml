<?xml version="1.0" encoding="utf-8"?>
<!--
	Publish shape for releases: self-contained win-x64, unpackaged.
	Used identically by installer/build-installer.ps1 locally and by .github/workflows/release.yml:
	  dotnet publish Ficsit.Schematics.csproj -f net10.0-windows10.0.19041.0 -p:PublishProfile=win-x64
-->
<Project>
	<PropertyGroup>
		<PublishProtocol>FileSystem</PublishProtocol>
		<Configuration>Release</Configuration>
		<Platform>x64</Platform>
		<RuntimeIdentifier>win-x64</RuntimeIdentifier>
		<SelfContained>true</SelfContained>
		<!-- Bundle the Windows App SDK runtime so target machines need no prerequisite installs -->
		<WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
		<PublishDir>bin\publish\win-x64\</PublishDir>
	</PropertyGroup>
</Project>
